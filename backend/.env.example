HF_TOKEN=your_huggingface_token_here
HF_FALLBACK_TOKEN=
HF_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_FALLBACK_MODEL=microsoft/Phi-3-mini-4k-instruct

DATABASE_URL=your_supabase_postgres_url_here
DB_MIN_CONNECTIONS=2
DB_MAX_CONNECTIONS=10

PORT=8000
MAX_QUESTIONS_DEFAULT=8
MAX_RETRIES=3
RETRY_DELAY_MS=1000
REQUEST_TIMEOUT_SECONDS=60

LOG_LEVEL=INFO
LOG_FORMAT=json

# Inference provider settings
# Set INFERENCE_PROVIDER=local to use a model served on Lightning or your own host
INFERENCE_PROVIDER=local
LOCAL_INFERENCE_URL=http://localhost:8001/v1/chat/completions
LOCAL_INFERENCE_TOKEN=

# Lightning-specific
LIGHTNING_ACCELERATOR=gpu
